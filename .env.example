# ── Required for Anthropic ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Model ─────────────────────────────────────────────────────────────────────
MODEL_PROVIDER=anthropic
MODEL=claude-sonnet-4-6
# Local model provider settings (used when MODEL_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT_SECONDS=300

# ── Commercial threat feeds ───────────────────────────────────────────────────
VIRUSTOTAL_API_KEY=
SHODAN_API_KEY=
RECORDED_FUTURE_API_KEY=

# ── Open-source feeds ─────────────────────────────────────────────────────────
OTX_API_KEY=
ABUSEIPDB_API_KEY=
# URLhaus and NVD require no key

# ── Internal / MISP ───────────────────────────────────────────────────────────
MISP_URL=https://misp.internal
MISP_API_KEY=
MISP_VERIFY_SSL=true

# ── SIEM integration ──────────────────────────────────────────────────────────
# SIEM_TYPE: file | webhook | syslog | api
SIEM_TYPE=file
SIEM_LOG_PATH=/var/log/siem/alerts.json
SIEM_URL=
SIEM_API_KEY=

# ── Storage ───────────────────────────────────────────────────────────────────
CACHE_DIR=.cache/argus
CACHE_SIZE_BYTES=1073741824
DB_PATH=.data/argus.db

# ── Output ────────────────────────────────────────────────────────────────────
REPORTS_DIR=reports
LOG_LEVEL=INFO
